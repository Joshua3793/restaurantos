{
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "target": "es2017",
    "downlevelIteration": true,
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": [
    "node_modules",
    "mobile",
    "prisma/migrate-sqlite-to-postgres.ts",
    "prisma/seed.ts",
    "prisma/seed-count.ts",
    "prisma/seed-recipes.ts",
    "scripts/migrate-sqlite-to-pg.ts",
    "scripts/backfill-supplier-offers.ts",
    "scripts/analyze-uom-normalization.ts",
    "scripts/import-sysco-catalog.ts",
    "scripts/seed-non-stocked.ts",
    "scripts/verify-inventory-import.ts",
    "scripts/verify-invoice-pricing.ts",
    "scripts/repair-count-uom.ts",
    "scripts/migrate-allocations-to-base.ts",
    "scripts/normalize-purchase-unit.ts",
    "scripts/relabel-each-to-case.ts",
    "scripts/repair-pull-soh.ts",
    "scripts/verify-count-conversion.ts"
  ]
}
