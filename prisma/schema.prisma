generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model StorageArea {
  id    String          @id @default(cuid())
  name  String
  items InventoryItem[]
}

model Category {
  id   String @id @default(cuid())
  name String @unique
}

model Supplier {
  id            String   @id @default(cuid())
  name          String
  contactName   String?
  phone         String?
  email         String?
  orderPlatform String?
  cutoffDays    String?
  deliveryDays  String?
  inventory        InventoryItem[]
  invoices         Invoice[]
  invoiceSessions  InvoiceSession[] @relation("SupplierInvoiceSessions")
  supplierPrices   InventorySupplierPrice[]
  createdAt        DateTime @default(now())
}

model InventoryItem {
  id                 String       @id @default(cuid())
  itemName           String
  category           String       @default("DRY")
  supplierId         String?
  supplier           Supplier?    @relation(fields: [supplierId], references: [id])
  storageAreaId      String?
  storageArea        StorageArea? @relation(fields: [storageAreaId], references: [id])
  purchaseUnit       String
  qtyPerPurchaseUnit Decimal      @default(1)
  purchasePrice      Decimal      @default(0)
  baseUnit           String       @default("each")
  packSize           Decimal      @default(1)
  packUOM            String       @default("each")
  countUOM           String       @default("each")
  conversionFactor   Decimal      @default(1)
  pricePerBaseUnit   Decimal      @default(0)
  stockOnHand        Decimal      @default(0)
  lastUpdated        DateTime     @default(now()) @updatedAt
  abbreviation       String?
  location           String?
  allergens          String[]     @default([])
  isActive           Boolean      @default(true)
  lastCountDate      DateTime?
  lastCountQty       Decimal?
  invoiceLineItems   InvoiceLineItem[]
  recipeIngredients  RecipeIngredient[] @relation("RecipeIngredientInventory")
  recipe             Recipe?            @relation("RecipeInventoryItem")
  wastageLogs        WastageLog[]
  countLines         CountLine[]
  snapshots          InventorySnapshot[]
  invoiceMatches     InvoiceScanItem[]  @relation("InventoryInvoiceMatches")
  matchRules         InvoiceMatchRule[] @relation("InventoryMatchRules")
  supplierPrices     InventorySupplierPrice[] @relation("InventorySupplierPrices")
  priceAlerts        PriceAlert[]       @relation("InventoryPriceAlerts")
  prepItems          PrepItem[]         @relation("PrepItemInventory")
}

model Invoice {
  id            String          @id @default(cuid())
  supplierId    String
  supplier      Supplier        @relation(fields: [supplierId], references: [id])
  invoiceDate   DateTime
  invoiceNumber String
  imageUrl      String?
  totalAmount   Decimal         @default(0)
  status        String          @default("PENDING")
  ocrRawData    String?
  createdAt     DateTime        @default(now())
  lineItems     InvoiceLineItem[]
}

model InvoiceLineItem {
  id              String        @id @default(cuid())
  invoiceId       String
  invoice         Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  qtyPurchased    Decimal
  unitPrice       Decimal
  lineTotal       Decimal       @default(0)
  priceOverride   Decimal?
  rawDescription  String?
}

model RecipeCategory {
  id        String    @id @default(uuid())
  name      String
  type      String    // 'PREP' | 'MENU'
  color     String?
  sortOrder Int       @default(0)
  recipes   Recipe[]
}

model Recipe {
  id              String             @id @default(uuid())
  name            String
  type            String             // 'PREP' | 'MENU'
  categoryId      String
  category        RecipeCategory     @relation(fields: [categoryId], references: [id])
  inventoryItemId String?            @unique
  inventoryItem   InventoryItem?     @relation("RecipeInventoryItem", fields: [inventoryItemId], references: [id])
  baseYieldQty    Decimal
  yieldUnit       String
  portionSize     Decimal?
  portionUnit     String?
  menuPrice       Decimal?
  isActive        Boolean            @default(true)
  notes           String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  ingredients     RecipeIngredient[] @relation("RecipeToIngredients")
  usedInRecipes   RecipeIngredient[] @relation("RecipeAsIngredient")
  saleLineItems   SaleLineItem[]
  recipeAlerts    RecipeAlert[]      @relation("RecipeAlerts")
  prepItems       PrepItem[]         @relation("PrepItemRecipe")
}

model RecipeIngredient {
  id              String         @id @default(uuid())
  recipeId        String
  recipe          Recipe         @relation("RecipeToIngredients", fields: [recipeId], references: [id], onDelete: Cascade)
  inventoryItemId String?
  inventoryItem   InventoryItem? @relation("RecipeIngredientInventory", fields: [inventoryItemId], references: [id])
  linkedRecipeId  String?
  linkedRecipe    Recipe?        @relation("RecipeAsIngredient", fields: [linkedRecipeId], references: [id])
  qtyBase         Decimal
  unit            String
  sortOrder       Int            @default(0)
  notes           String?
  recipePercent   Decimal?
}

model CountSession {
  id                String              @id @default(uuid())
  sessionDate       DateTime
  label             String
  type              String              @default("FULL")
  areaFilter        String?
  countedBy         String
  status            String              @default("IN_PROGRESS")
  startedAt         DateTime            @default(now())
  finalizedAt       DateTime?
  totalCountedValue Decimal             @default(0)
  notes             String?
  lines             CountLine[]
  snapshots         InventorySnapshot[]
}

model CountLine {
  id              String        @id @default(uuid())
  sessionId       String
  session         CountSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  expectedQty     Decimal
  countedQty      Decimal?
  selectedUom     String
  skipped         Boolean       @default(false)
  variancePct     Decimal?
  varianceCost    Decimal?
  priceAtCount    Decimal
  notes           String?
  sortOrder       Int           @default(0)
}

model InventorySnapshot {
  id               String        @id @default(uuid())
  sessionId        String
  session          CountSession  @relation(fields: [sessionId], references: [id])
  inventoryItemId  String
  inventoryItem    InventoryItem @relation(fields: [inventoryItemId], references: [id])
  snapshotDate     DateTime
  qtyOnHand        Decimal
  unit             String
  pricePerBaseUnit Decimal
  totalValue       Decimal
  category         String
}

model WastageLog {
  id              String        @id @default(cuid())
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  date            DateTime      @default(now())
  qtyWasted       Decimal
  unit            String
  reason          String        @default("UNKNOWN")
  costImpact      Decimal       @default(0)
  loggedBy        String        @default("System")
  notes           String?
}

model SalesEntry {
  id           String         @id @default(cuid())
  date         DateTime
  totalRevenue Decimal
  foodSalesPct Decimal        @default(0.7)
  covers       Int?
  notes        String?
  createdAt    DateTime       @default(now())
  lineItems    SaleLineItem[]
}

model SaleLineItem {
  id       String     @id @default(uuid())
  saleId   String
  sale     SalesEntry @relation(fields: [saleId], references: [id], onDelete: Cascade)
  recipeId String
  recipe   Recipe     @relation(fields: [recipeId], references: [id])
  qtySold  Int        @default(0)
}

// ── Invoice Scanner ───────────────────────────────────────────────────────────
// Note: SQLite doesn't support enums — all enum-like fields use String with constants

// InvoiceStatus: UPLOADING | PROCESSING | REVIEW | APPROVED | REJECTED
// OcrStatus:     PENDING | PROCESSING | COMPLETE | ERROR
// MatchConfidence: HIGH | MEDIUM | LOW | NONE
// LineItemAction: PENDING | UPDATE_PRICE | ADD_SUPPLIER | CREATE_NEW | SKIP
// AlertDirection: UP | DOWN

model InvoiceSession {
  id            String    @id @default(uuid())
  status        String    @default("UPLOADING")
  supplierName  String?
  supplierId    String?
  supplier      Supplier? @relation("SupplierInvoiceSessions", fields: [supplierId], references: [id])
  invoiceDate   String?
  invoiceNumber String?
  subtotal      Decimal?
  tax           Decimal?
  total         Decimal?
  approvedBy    String?
  approvedAt    DateTime?
  createdAt     DateTime  @default(now())
  files         InvoiceFile[]
  scanItems     InvoiceScanItem[]
  priceAlerts   PriceAlert[]
  recipeAlerts  RecipeAlert[]
}

model InvoiceFile {
  id          String         @id @default(uuid())
  sessionId   String
  session     InvoiceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  fileName    String
  fileType    String
  fileUrl     String         // UploadThing CDN URL
  ocrStatus   String         @default("PENDING")
  ocrRawJson  String?
  createdAt   DateTime       @default(now())
}

model InvoiceScanItem {
  id              String         @id @default(uuid())
  sessionId       String
  session         InvoiceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  rawDescription  String
  rawQty          Decimal?
  rawUnit         String?
  rawUnitPrice    Decimal?
  rawLineTotal    Decimal?
  matchedItemId   String?
  matchedItem     InventoryItem? @relation("InventoryInvoiceMatches", fields: [matchedItemId], references: [id])
  matchConfidence String         @default("NONE")
  matchScore      Int            @default(0)
  action          String         @default("PENDING")
  approved        Boolean        @default(false)
  isNewItem       Boolean        @default(false)
  newItemData     String?        // JSON
  previousPrice   Decimal?
  newPrice        Decimal?
  priceDiffPct    Decimal?
  formatMismatch     Boolean        @default(false)
  invoicePackQty     Decimal?
  invoicePackSize    Decimal?
  invoicePackUOM     String?
  needsFormatConfirm Boolean        @default(false)
  sortOrder          Int            @default(0)
}

model InventorySupplierPrice {
  id               String        @id @default(uuid())
  inventoryItemId  String
  inventoryItem    InventoryItem @relation("InventorySupplierPrices", fields: [inventoryItemId], references: [id], onDelete: Cascade)
  supplierName     String
  supplierId       String?
  supplier         Supplier?     @relation(fields: [supplierId], references: [id])
  lastPrice        Decimal
  pricePerBaseUnit Decimal
  lastUpdated      DateTime      @default(now())
  isPrimary        Boolean       @default(false)
}

model PriceAlert {
  id              String         @id @default(uuid())
  sessionId       String
  session         InvoiceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  inventoryItemId String
  inventoryItem   InventoryItem  @relation("InventoryPriceAlerts", fields: [inventoryItemId], references: [id])
  previousPrice   Decimal
  newPrice        Decimal
  changePct       Decimal
  direction       String
  acknowledged    Boolean        @default(false)
  createdAt       DateTime       @default(now())
}

// Learned invoice→inventory matches. Built up each time a user confirms/overrides a match.
model InvoiceMatchRule {
  id              String        @id @default(cuid())
  rawDescription  String
  supplierName    String        @default("")   // empty string = no supplier
  inventoryItemId String
  inventoryItem   InventoryItem @relation("InventoryMatchRules", fields: [inventoryItemId], references: [id])
  invoicePackQty  Decimal?
  invoicePackSize Decimal?
  invoicePackUOM  String?
  useCount        Int           @default(1)
  lastUsed        DateTime      @default(now())
  createdAt       DateTime      @default(now())

  @@unique([rawDescription, supplierName])
}

model RecipeAlert {
  id                String         @id @default(uuid())
  sessionId         String
  session           InvoiceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  recipeId          String
  recipe            Recipe         @relation("RecipeAlerts", fields: [recipeId], references: [id])
  previousCost      Decimal
  newCost           Decimal
  changePct         Decimal
  newFoodCostPct    Decimal?
  exceededThreshold Boolean        @default(false)
  acknowledged      Boolean        @default(false)
  createdAt         DateTime       @default(now())
}

model PrepItem {
  id                     String         @id @default(uuid())
  name                   String
  linkedRecipeId         String?
  linkedRecipe           Recipe?        @relation("PrepItemRecipe", fields: [linkedRecipeId], references: [id])
  linkedInventoryItemId  String?
  linkedInventoryItem    InventoryItem? @relation("PrepItemInventory", fields: [linkedInventoryItemId], references: [id])
  category               String         @default("MISC")
  station                String?
  parLevel               Decimal        @default(0)
  unit                   String         @default("batch")
  minThreshold           Decimal        @default(0)
  targetToday            Decimal?
  shelfLifeDays          Int?
  notes                  String?
  manualPriorityOverride String?
  isActive               Boolean        @default(true)
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  logs                   PrepLog[]
}

model PrepLog {
  id                String   @id @default(uuid())
  prepItemId        String
  prepItem          PrepItem @relation(fields: [prepItemId], references: [id], onDelete: Cascade)
  logDate           DateTime
  status            String   @default("NOT_STARTED")
  requiredQty       Decimal?
  actualPrepQty     Decimal?
  assignedTo        String?
  dueTime           String?
  note              String?
  blockedReason     String?
  inventoryAdjusted Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([prepItemId, logDate])
}
