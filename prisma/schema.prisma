generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  OWNER
  ADMIN
  MANAGER
  LEAD
  STAFF
}

// Item physical dimension — declared, never guessed. Implies the SI base unit
// (MASS→g, VOLUME→ml, COUNT→each). Part of the pack-chain item model.
enum Dimension {
  MASS
  VOLUME
  COUNT
}

// NOTE: at most one OWNER is enforced by a raw partial unique index —
// "User_single_owner" ON "User" ("role") WHERE "role" = 'OWNER', hand-written
// into the clearance_tables migration. Prisma can't express a partial index,
// so nothing below mentions it. (Same can't-express-it-in-schema situation as
// the "UserScope_user_node_unique" index below, just applied a different
// way — via migration SQL here, vs. out-of-band via a script there.)
model User {
  id                String             @id
  email             String             @unique
  name              String?
  role              Role               @default(STAFF)
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  chatConversations ChatConversation[]
  scopes            UserScope[]
  auditEventsActed    AccessAuditEvent[] @relation("AuditActor")
  auditEventsReceived AccessAuditEvent[] @relation("AuditTarget")
}

// Append-only log of access changes. Actor and target ids are SetNull so a
// hard-deleted user blanks the id but leaves the row; the denormalized
// email/name columns are what keep the entry readable afterwards.
model AccessAuditEvent {
  id           String   @id @default(cuid())
  actorId      String?
  actor        User?    @relation("AuditActor",  fields: [actorId],      references: [id], onDelete: SetNull)
  actorEmail   String
  actorName    String?
  targetUserId String?
  target       User?    @relation("AuditTarget", fields: [targetUserId], references: [id], onDelete: SetNull)
  targetEmail  String
  targetName   String?
  action       String
  detail       Json     @default("{}")
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([targetUserId])
}

model StorageArea {
  id    String          @id @default(cuid())
  name  String
  items InventoryItem[]
}

model Category {
  id   String @id @default(cuid())
  name String @unique
}

model Supplier {
  id              String                   @id @default(cuid())
  name            String
  contactName     String?
  phone           String?
  email           String?
  orderPlatform   String?
  cutoffDays      String?
  deliveryDays    String?
  ocrFormatNotes  String? // column-layout notes discovered by learning-mode OCR; injected into future OCR prompts
  createdAt       DateTime                 @default(now())
  inventory       InventoryItem[]
  supplierPrices  InventorySupplierPrice[]
  invoices        Invoice[]
  invoiceSessions InvoiceSession[]         @relation("SupplierInvoiceSessions")
  aliases         SupplierAlias[]
}

model SupplierAlias {
  id         String   @id @default(cuid())
  supplierId String
  name       String
  createdAt  DateTime @default(now())
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@unique([supplierId, name])
}

model InventoryItem {
  id                 String                   @id @default(cuid())
  itemName           String
  category           String                   @default("DRY")
  supplierId         String?
  storageAreaId      String?
  purchasePrice      Decimal                  @default(0)
  baseUnit           String                   @default("each")
  needsReview        Boolean                  @default(false) // flagged by migration script for manual review
  // REMOVED (computed on-read / replaced by the pack chain):
  //   pricePerBaseUnit, conversionFactor — derived from packChain/pricing
  //   purchaseUnit, qtyPerPurchaseUnit, packSize, packUOM, qtyUOM, innerQty,
  //   priceType, countUOM — replaced by dimension/packChain/pricing/countUnit
  // ── Pack-chain item model (the single source of truth) ──────────────────────
  dimension          Dimension                @default(COUNT)
  packChain          Json                     @default("[]")        // PackLink[] outer→inner; leaf.per in baseUnit
  pricing            Json                     @default("{\"mode\":\"PACK\",\"purchasePrice\":0}")
  countUnit          String                   @default("each")      // a chain level OR a same-dimension unit
  stockOnHand        Decimal                  @default(0)
  createdAt          DateTime                 @default(now())
  lastUpdated        DateTime                 @default(now()) @updatedAt
  location           String?
  isActive           Boolean                  @default(true)
  isStocked          Boolean                  @default(true) // false = recipe-only utility ingredient (e.g. tap water); excluded from counts/valuation/purchasing/theoretical stock
  lastCountDate      DateTime?
  lastCountQty       Decimal?
  allergens          String[]                 @default([])
  barcode            String?
  // ── Count↔weight bridge (COUNT items only) ──────────────────────────────────
  // Canonical measure of ONE base count unit, e.g. 1 each (loaf) = 1100 g.
  // Lets weight-format invoices normalize to count and weight-based recipes cost.
  eachMeasureQty     Decimal?                 // measure of 1 base unit (e.g. 1100)
  eachMeasureUnit    String?                  // its unit, base-canonical (g | ml)
  // ── Weight↔volume density bridge (measured items) ───────────────────────────
  // Grams per millilitre for THIS good. Lets a weight invoice ($/kg) set the
  // spine of a volume-based item (and vice-versa) without the silent density≈1
  // assumption. Null = unknown (callers fall back to 1.0, flagged as estimate).
  densityGPerMl      Decimal?
  countLines         CountLine[]
  storageArea        StorageArea?             @relation(fields: [storageAreaId], references: [id])
  supplier           Supplier?                @relation(fields: [supplierId], references: [id])
  snapshots          InventorySnapshot[]
  supplierPrices     InventorySupplierPrice[] @relation("InventorySupplierPrices")
  invoiceLineItems   InvoiceLineItem[]
  matchRules         InvoiceMatchRule[]       @relation("InventoryMatchRules")
  invoiceMatches     InvoiceScanItem[]        @relation("InventoryInvoiceMatches")
  prepItems          PrepItem[]               @relation("PrepItemInventory")
  prepTaskRefs       PrepTask[]               @relation("PrepTaskInventory")
  priceAlerts        PriceAlert[]             @relation("InventoryPriceAlerts")
  recipe             Recipe?                  @relation("RecipeInventoryItem")
  recipeIngredients  RecipeIngredient[]       @relation("RecipeIngredientInventory")
  stockAllocations   StockAllocation[]
  stockTransfers     StockTransfer[]
  wastageLogs        WastageLog[]
  revenueCenters     ItemRevenueCenter[]
}

model Invoice {
  id            String            @id @default(cuid())
  supplierId    String
  invoiceDate   DateTime
  invoiceNumber String
  imageUrl      String?
  totalAmount   Decimal           @default(0)
  status        String            @default("PENDING")
  ocrRawData    String?
  createdAt     DateTime          @default(now())
  supplier      Supplier          @relation(fields: [supplierId], references: [id])
  lineItems     InvoiceLineItem[]
}

model InvoiceLineItem {
  id              String        @id @default(cuid())
  invoiceId       String
  inventoryItemId String
  qtyPurchased    Decimal
  unitPrice       Decimal
  lineTotal       Decimal       @default(0)
  priceOverride   Decimal?
  rawDescription  String?
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  invoice         Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model RecipeCategory {
  id              String         @id @default(uuid())
  name            String
  type            String
  color           String?
  sortOrder       Int            @default(0)
  revenueCenterId String?
  recipes         Recipe[]
  revenueCenter   RevenueCenter? @relation("MenuCategoryRC", fields: [revenueCenterId], references: [id])
}

model Recipe {
  id              String             @id @default(uuid())
  name            String
  type            String
  categoryId      String
  inventoryItemId String?            @unique
  baseYieldQty    Decimal
  yieldUnit       String
  portionSize     Decimal?
  portionUnit     String?
  menuPrice       Decimal?
  isActive        Boolean            @default(true)
  notes            String?
  steps           String[]           @default([])
  baseIngredientId String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  revenueCenterId  String?
  activeMinutes   Int?
  passiveMinutes  Int?
  passiveNote     String?
  prepItems       PrepItem[]         @relation("PrepItemRecipe")
  category        RecipeCategory     @relation(fields: [categoryId], references: [id])
  inventoryItem   InventoryItem?     @relation("RecipeInventoryItem", fields: [inventoryItemId], references: [id])
  revenueCenter   RevenueCenter?     @relation("MenuRC", fields: [revenueCenterId], references: [id])
  recipeAlerts    RecipeAlert[]      @relation("RecipeAlerts")
  usedInRecipes   RecipeIngredient[] @relation("RecipeAsIngredient")
  ingredients     RecipeIngredient[] @relation("RecipeToIngredients")
  saleLineItems   SaleLineItem[]
  toastItemMaps   ToastItemMap[]     @relation("ToastItemRecipe") // schema-only (Toast feature paused)
}

model RecipeIngredient {
  id              String         @id @default(uuid())
  recipeId        String
  inventoryItemId String?
  linkedRecipeId  String?
  qtyBase         Decimal
  unit            String
  sortOrder       Int            @default(0)
  notes           String?
  customName      String?
  recipePercent   Decimal?
  inventoryItem   InventoryItem? @relation("RecipeIngredientInventory", fields: [inventoryItemId], references: [id])
  linkedRecipe    Recipe?        @relation("RecipeAsIngredient", fields: [linkedRecipeId], references: [id])
  recipe          Recipe         @relation("RecipeToIngredients", fields: [recipeId], references: [id], onDelete: Cascade)
}

model CountSession {
  id                String              @id @default(uuid())
  sessionDate       DateTime
  label             String
  type              String              @default("FULL")
  areaFilter        String?
  countedBy         String
  status            String              @default("IN_PROGRESS")
  startedAt         DateTime            @default(now())
  finalizedAt       DateTime?
  totalCountedValue Decimal             @default(0)
  notes             String?
  revenueCenterId   String?
  lines             CountLine[]
  revenueCenter     RevenueCenter?      @relation("CountRC", fields: [revenueCenterId], references: [id])
  snapshots         InventorySnapshot[]
}

model CountLine {
  id              String        @id @default(uuid())
  sessionId       String
  inventoryItemId String
  expectedQty     Decimal
  countedQty      Decimal?
  selectedUom     String
  // Optional mixed-unit count: [{ unit, qty }] summed to base. When present it is
  // authoritative; countedQty/selectedUom remain as the single-unit fallback + display.
  entries         Json?
  skipped         Boolean       @default(false)
  noMovement      Boolean       @default(false)
  carriedForward  Boolean       @default(false)
  variancePct     Decimal?
  varianceCost    Decimal?
  priceAtCount    Decimal
  notes           String?
  sortOrder       Int           @default(0)
  updatedAt       DateTime      @default(now()) @updatedAt
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  session         CountSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model InventorySnapshot {
  id               String        @id @default(uuid())
  sessionId        String
  inventoryItemId  String
  snapshotDate     DateTime
  qtyOnHand        Decimal
  unit             String
  pricePerBaseUnit Decimal
  totalValue       Decimal
  category         String
  inventoryItem    InventoryItem @relation(fields: [inventoryItemId], references: [id])
  session          CountSession  @relation(fields: [sessionId], references: [id])
}

model WastageLog {
  id              String         @id @default(cuid())
  inventoryItemId String
  date            DateTime       @default(now())
  qtyWasted       Decimal
  unit            String
  reason          String         @default("UNKNOWN")
  costImpact      Decimal        @default(0)
  loggedBy        String         @default("System")
  notes           String?
  revenueCenterId String
  inventoryItem   InventoryItem  @relation(fields: [inventoryItemId], references: [id])
  revenueCenter   RevenueCenter  @relation("WastageRC", fields: [revenueCenterId], references: [id])

  // buildWastageMap filters wastage by revenueCenterId + date range.
  @@index([revenueCenterId, date])
}

model SalesEntry {
  id              String         @id @default(cuid())
  date            DateTime
  totalRevenue    Decimal
  foodSalesPct    Decimal        @default(0.7)
  covers          Int?
  notes           String?
  periodType      String         @default("day")
  endDate         DateTime?
  createdAt       DateTime       @default(now())
  revenueCenterId String
  source          String         @default("manual") // 'manual' | 'toast' — schema-only (Toast feature paused; tables exist in DB)
  lineItems       SaleLineItem[]
  revenueCenter   RevenueCenter  @relation("SalesRC", fields: [revenueCenterId], references: [id])

  @@unique([date, revenueCenterId, source, periodType])
}

model SaleLineItem {
  id       String     @id @default(uuid())
  saleId   String
  recipeId String
  qtySold  Int        @default(0)
  recipe   Recipe     @relation(fields: [recipeId], references: [id])
  sale     SalesEntry @relation(fields: [saleId], references: [id], onDelete: Cascade)
}

model InvoiceSession {
  id              String            @id @default(uuid())
  status          String            @default("UPLOADING")
  supplierName    String?
  supplierId      String?
  invoiceDate     String?
  invoiceNumber   String?
  poNumber        String?
  subtotal        Decimal?
  tax             Decimal?          // legacy aggregate — equals gst+hst+pst when those are populated
  discount        Decimal?
  fuelSurcharge   Decimal?
  freight         Decimal?
  minimumOrderFee Decimal?
  gst             Decimal?
  hst             Decimal?
  pst             Decimal?
  otherCharges    Json?             // Array<{ label: string; amount: number }>
  total           Decimal?
  errorMessage    String?
  approvedBy      String?
  approvedAt      DateTime?
  // The accounting/received date a purchase lands on. Resolved at approval from the
  // OCR invoiceDate string (falling back to approvedAt when it's missing/unparseable).
  // ALL purchase-spend reporting windows on this, NOT approvedAt, so a June-dated
  // invoice approved in July still counts toward June. See src/lib/purchase-date.ts.
  purchaseDate    DateTime?
  createdAt       DateTime          @default(now())
  parentSessionId String?
  revenueCenterId String?
  files           InvoiceFile[]
  scanItems       InvoiceScanItem[]
  parent          InvoiceSession?   @relation("SessionClones", fields: [parentSessionId], references: [id])
  clones          InvoiceSession[]  @relation("SessionClones")
  revenueCenter   RevenueCenter?    @relation("SessionRC", fields: [revenueCenterId], references: [id])
  supplier        Supplier?         @relation("SupplierInvoiceSessions", fields: [supplierId], references: [id])
  priceAlerts     PriceAlert[]
  recipeAlerts    RecipeAlert[]

  @@index([purchaseDate])
}

model InvoiceFile {
  id         String         @id @default(uuid())
  sessionId  String
  fileName   String
  fileType   String
  fileUrl    String
  ocrStatus  String         @default("PENDING")
  ocrRawJson String?
  // Degrees (0/90/180/270) to rotate the stored image CLOCKWISE so its text is
  // upright — the orientation Claude's bbox coordinates are expressed in. The
  // viewer rotates the display by this so highlights trace the rows.
  displayRotation Int        @default(0)
  createdAt  DateTime       @default(now())
  session    InvoiceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model InvoiceScanItem {
  id                 String         @id @default(uuid())
  sessionId          String
  rawDescription     String
  rawQty             Decimal?
  rawUnit            String?
  rawUnitPrice       Decimal?
  rawLineTotal       Decimal?
  matchedItemId      String?
  matchConfidence    String         @default("NONE")
  matchScore         Int            @default(0)
  action             String         @default("PENDING")
  approved           Boolean        @default(false)
  isNewItem          Boolean        @default(false)
  newItemData        String?
  previousPrice      Decimal?
  newPrice           Decimal?
  priceDiffPct       Decimal?
  sortOrder          Int            @default(0)
  invoicePackQty     Decimal?
  invoicePackSize    Decimal?
  invoicePackUOM     String?
  totalQty           Decimal?
  totalQtyUOM        String?
  revenueCenterId    String?
  splitToSessionId   String?        // set on a PARENT line moved into an RC clone; null = live/countable
  // Per-RC quantity split (count UOM): [{ rcId, qty }]. When set, the line's
  // received quantity + cost fan out proportionally across these RCs on approve
  // (overrides revenueCenterId). Sum of qty must equal the line's received qty.
  rcSplit            Json?
  ocrConfidence      String?        // 'low' | 'medium' | 'high' — Claude's self-rated confidence in this line
  ocrNotes           String?        // Optional reason Claude flagged a line as low-confidence
  // ── Mode-aware OCR fields (from the mode-first OCR schema) ─────────────────
  pricingMode        String?        // 'per_case' | 'per_weight' | 'unknown'
  pricingModeSignal  String?        // 'explicit_per_column' | 'price_uom_is_weight' | 'weight_column_present' | 'math_inference' | 'default_case' | 'indeterminate'
  qtyOrdered         Decimal?
  qtyOrderedUOM      String?
  rate               Decimal?       // $/uom for per_weight lines
  rateUOM            String?
  isCatchweight      Boolean        @default(false)
  nominalWeight      Decimal?       // packQty × packSize when packUOM is weight/volume and differs from totalQty
  lineCategory       String?        // section header ("DAIRY") or column code ("PR", "DS")
  supplierItemCode   String?        // per-line product code from invoice
  taxFlag            String?        // row-level tax code ("B", "G", "GP")
  lineTaxAmount      Decimal?       // inline tax shown on row (Snow Cap style)
  bbox               Json?          // { page, x, y, w, h } — 0-1 fractions of image dims, for highlight overlay
  matchedItem        InventoryItem? @relation("InventoryInvoiceMatches", fields: [matchedItemId], references: [id])
  revenueCenter      RevenueCenter? @relation("ScanItemRC", fields: [revenueCenterId], references: [id])
  session            InvoiceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([matchedItemId])
  @@index([splitToSessionId])
}

model InventorySupplierPrice {
  id                   String        @id @default(uuid())
  inventoryItemId      String
  supplierName         String
  supplierId           String?
  lastPrice            Decimal
  // pricePerBaseUnit removed — offer ppb derives from packChain/pricing via offerPricePerBase()
  lastUpdated          DateTime      @default(now())
  isPrimary            Boolean       @default(false)
  supplierItemCode     String?  // this supplier's SKU for the item
  // RETAINED human pack format ("4 × 3 L") — provenance/display only. The chain
  // (packChain/pricing) is the costing source of truth; these are NOT a divergence
  // risk and are NOT fully derivable from the normalized chain for single-link offers.
  packQty              Decimal? // THIS supplier's pack format (qty per case)
  packSize             Decimal?
  packUOM              String?
  // Per-offer pack-chain model (the design's ItemOffer): each supplier offer
  // carries its own chain + pricing so its pricePerBaseUnit derives on read and
  // cross-supplier comparison is one numeric compare. Legacy packQty/size/UOM +
  // pricePerBaseUnit stay as fallback/provenance.
  packChain            Json?
  pricing              Json?
  lastInvoiceSessionId String?  // provenance: approval that last set this offer
  inventoryItem        InventoryItem @relation("InventorySupplierPrices", fields: [inventoryItemId], references: [id], onDelete: Cascade)
  supplier             Supplier?     @relation(fields: [supplierId], references: [id])

  @@unique([inventoryItemId, supplierName])
}

model PriceAlert {
  id              String         @id @default(uuid())
  sessionId       String
  inventoryItemId String
  previousPrice   Decimal
  newPrice        Decimal
  changePct       Decimal
  direction       String
  acknowledged    Boolean        @default(false)
  createdAt       DateTime       @default(now())
  inventoryItem   InventoryItem  @relation("InventoryPriceAlerts", fields: [inventoryItemId], references: [id])
  session         InvoiceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model InvoiceMatchRule {
  id              String        @id @default(cuid())
  rawDescription  String
  supplierName    String        @default("")
  inventoryItemId String
  useCount        Int           @default(1)
  lastUsed        DateTime      @default(now())
  createdAt       DateTime      @default(now())
  // RETAINED learned pack-format cache. The matcher re-applies this {qty,size,UOM}
  // triple to new scan lines (buildMatchResult consumes the triple, not a chain).
  // Intentionally NOT migrated to packChain — the triple is the human format, not a cost.
  invoicePackQty  Decimal?
  invoicePackSize Decimal?
  invoicePackUOM  String?
  supplierItemCode String?
  inventoryItem   InventoryItem @relation("InventoryMatchRules", fields: [inventoryItemId], references: [id])

  @@unique([rawDescription, supplierName])
  @@index([supplierName, supplierItemCode])
}

model RecipeAlert {
  id                String         @id @default(uuid())
  sessionId         String
  recipeId          String
  previousCost      Decimal
  newCost           Decimal
  changePct         Decimal
  newFoodCostPct    Decimal?
  exceededThreshold Boolean        @default(false)
  acknowledged      Boolean        @default(false)
  createdAt         DateTime       @default(now())
  recipe            Recipe         @relation("RecipeAlerts", fields: [recipeId], references: [id])
  session           InvoiceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model PrepItem {
  id                     String         @id @default(uuid())
  name                   String
  linkedRecipeId         String?
  linkedInventoryItemId  String?
  category               String         @default("MISC")
  station                String?
  parLevel               Decimal        @default(0)
  unit                   String         @default("batch")
  minThreshold           Decimal        @default(0)
  targetToday            Decimal?
  shelfLifeDays          Int?
  notes                  String?
  manualPriorityOverride String?
  isActive               Boolean        @default(true)
  isOnList               Boolean        @default(false)
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  estimatedPrepTime      Int?
  revenueCenterId        String?
  targetServiceId        String?
  activeMinutesOverride  Int?
  passiveMinutesOverride Int?
  passiveNoteOverride    String?
  linkedInventoryItem    InventoryItem? @relation("PrepItemInventory", fields: [linkedInventoryItemId], references: [id])
  linkedRecipe           Recipe?        @relation("PrepItemRecipe", fields: [linkedRecipeId], references: [id])
  revenueCenter          RevenueCenter? @relation("PrepItemRC", fields: [revenueCenterId], references: [id])
  targetService          Service? @relation("PrepItemService", fields: [targetServiceId], references: [id])
  logs                   PrepLog[]
}

model PrepLog {
  id                String   @id @default(uuid())
  prepItemId        String
  revenueCenterId   String
  logDate           DateTime
  status            String   @default("NOT_STARTED")
  requiredQty       Decimal?
  actualPrepQty     Decimal?
  assignedTo        String?
  dueTime           String?
  note              String?
  blockedReason     String?
  inventoryAdjusted Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  startedAt         DateTime?
  completedAt       DateTime?
  prepItem          PrepItem       @relation(fields: [prepItemId], references: [id], onDelete: Cascade)
  revenueCenter     RevenueCenter  @relation("PrepLogRC", fields: [revenueCenterId], references: [id])

  @@unique([prepItemId, logDate])
  // Theoretical-stock scans (buildPrepMap) filter DONE/PARTIAL logs by revenueCenterId
  // + logDate range; the unique above leads with prepItemId so it can't serve that scan.
  @@index([revenueCenterId, logDate])
}

model PrepSettings {
  id         String   @id @default("singleton")
  categories String[]
  stations   String[]
  updatedAt  DateTime @updatedAt
}

model Location {
  id              String          @id @default(cuid())
  name            String
  color           String
  type            String          @default("restaurant") // restaurant | catering | other
  isDefault       Boolean         @default(false)        // primary business (distinct from RevenueCenter.isDefault)
  description     String?
  isActive        Boolean         @default(true)
  managerName     String?
  notes           String?
  schedulingMode  String          @default("FIXED")
  prepLeadMinutes Int?
  serviceSchedule Json?
  createdAt       DateTime        @default(now())
  defaultRevenueCenterId String?
  defaultRevenueCenter   RevenueCenter? @relation("LocationDefaultRC", fields: [defaultRevenueCenterId], references: [id], onDelete: SetNull)
  revenueCenters  RevenueCenter[]
  userScopes      UserScope[]
  toastMaps       ToastRevenueCenterMap[] @relation("ToastLocationMap")
}

model RevenueCenter {
  id                String            @id @default(cuid())
  name              String
  color             String
  isDefault         Boolean           @default(false)
  createdAt         DateTime          @default(now())
  description       String?
  isActive          Boolean           @default(true)
  managerName       String?
  notes             String?
  targetFoodCostPct Decimal?
  targetCostPct     Decimal?
  type              String            @default("FOOD")
  locationId        String
  location          Location          @relation(fields: [locationId], references: [id], onDelete: Restrict)
  prepLeadMinutes   Int?
  toastGuid         String?           @unique // SUPERSEDED by ToastRevenueCenterMap (many Toast RCs → one app RC); unused, retained until dropped
  toastRcMaps       ToastRevenueCenterMap[] @relation("ToastRCMap")
  countSessions     CountSession[]    @relation("CountRC")
  scanItems         InvoiceScanItem[] @relation("ScanItemRC")
  invoiceSessions   InvoiceSession[]  @relation("SessionRC")
  menuRecipes       Recipe[]          @relation("MenuRC")
  menuCategories    RecipeCategory[]  @relation("MenuCategoryRC")
  salesEntries      SalesEntry[]      @relation("SalesRC")
  stockAllocations  StockAllocation[]
  transfersFrom     StockTransfer[]   @relation("TransferFrom")
  transfersTo       StockTransfer[]   @relation("TransferTo")
  wastageLog        WastageLog[]      @relation("WastageRC")
  tempUnits         TempUnit[]        @relation("TempUnitRC")
  prepItems         PrepItem[]        @relation("PrepItemRC")
  prepLogs          PrepLog[]         @relation("PrepLogRC")
  itemMemberships   ItemRevenueCenter[]
  prepTasks         PrepTask[]        @relation("PrepTaskRC")
  userScopes        UserScope[]
  defaultForLocations Location[]      @relation("LocationDefaultRC")
  eodCheckItems     EodCheckItem[]    @relation("EodCheckItemRC")
  eodCloses         EodClose[]        @relation("EodCloseRC")
  services          Service[]         @relation("ServiceRC")
}

model Service {
  id              String        @id @default(cuid())
  revenueCenterId String
  name            String
  timeMinutes     Int
  // Service END, minute-of-day. Nullable so this ships additively; the RC editor
  // requires it on save. endMinutes < timeMinutes ⇒ the service crosses midnight.
  endMinutes      Int?
  sortOrder       Int           @default(0)
  isActive        Boolean       @default(true)
  revenueCenter   RevenueCenter @relation("ServiceRC", fields: [revenueCenterId], references: [id])
  prepItems       PrepItem[]    @relation("PrepItemService")
  @@index([revenueCenterId])
}

model Cook {
  id          String  @id @default(cuid())
  name        String
  initials    String
  homeStation String?
  isActive    Boolean @default(true)
  sortOrder   Int     @default(0)
}

model UserScope {
  id              String         @id @default(cuid())
  userId          String
  locationId      String?
  revenueCenterId String?
  clearance       Role?          // null = inherit the user's primary clearance
  createdAt       DateTime       @default(now())
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  location        Location?      @relation(fields: [locationId], references: [id], onDelete: Cascade)
  revenueCenter   RevenueCenter? @relation(fields: [revenueCenterId], references: [id], onDelete: Cascade)

  // NOTE: this @@unique does NOT block duplicate rows when a column is NULL
  // (Postgres treats NULLs as distinct, and every row has exactly one of
  // locationId/revenueCenterId set). Real uniqueness is enforced by a raw
  // "UserScope_user_node_unique" index with NULLS NOT DISTINCT (Postgres 15+),
  // applied out-of-band via scripts/apply-userscope-index.ts — Prisma can't
  // express NULLS NOT DISTINCT. Kept here to keep the column tuple indexed.
  @@unique([userId, locationId, revenueCenterId])
  @@index([userId])
}

model StockAllocation {
  id              String        @id @default(cuid())
  revenueCenterId String
  inventoryItemId String
  quantity        Decimal       @default(0)
  parLevel        Decimal?
  reorderQty      Decimal?
  updatedAt       DateTime      @updatedAt
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  revenueCenter   RevenueCenter @relation(fields: [revenueCenterId], references: [id], onDelete: Cascade)

  @@unique([revenueCenterId, inventoryItemId])
}

// Explicit item↔revenue-center membership ("shared items"). Pure visibility/scope —
// no stock lives here. Controls which items appear in an RC's count. Stock stays in
// InventoryItem.stockOnHand (default RC) and StockAllocation (non-default). The default
// RC participates like any other RC. See docs/superpowers/specs/2026-06-24-item-rc-membership-design.md
model ItemRevenueCenter {
  id              String        @id @default(cuid())
  inventoryItemId String
  revenueCenterId String
  createdAt       DateTime      @default(now())
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  revenueCenter   RevenueCenter @relation(fields: [revenueCenterId], references: [id], onDelete: Cascade)

  @@unique([inventoryItemId, revenueCenterId])
  @@index([revenueCenterId])
}

model StockTransfer {
  id              String        @id @default(cuid())
  fromRcId        String
  toRcId          String
  inventoryItemId String
  quantity        Decimal
  notes           String?
  createdAt       DateTime      @default(now())
  fromRc          RevenueCenter @relation("TransferFrom", fields: [fromRcId], references: [id])
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  toRc            RevenueCenter @relation("TransferTo", fields: [toRcId], references: [id])

  @@index([fromRcId])
  @@index([toRcId])
  // buildTransferMap filters transfers by createdAt range (per RC via the rc indexes above).
  @@index([createdAt])
  @@index([inventoryItemId])
}

model ChatConversation {
  id        String        @id @default(cuid())
  userId    String?
  user      User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  title     String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]

  @@index([userId])
}

model ChatMessage {
  id             String           @id @default(cuid())
  conversationId String
  role           String
  content        String
  createdAt      DateTime         @default(now())
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

// v2 Signals engine — "what should I do?" recommendations.
// Produced by /api/signals/refresh (rule evaluator); user actions
// (apply, snooze, dismiss) write back here.
model Signal {
  id          String   @id @default(cuid())
  // Stable per-instance fingerprint so re-runs don't duplicate rows
  // for the same underlying condition. Format: rule:scope:hash.
  fingerprint String   @unique
  // Rule key from src/lib/signals/rules.ts
  rule        String
  // Severity: 'critical' | 'warn' | 'info'
  severity    String   @default("info")
  // Human title shown on the card
  title       String
  // One-sentence body
  body        String
  // Verb on the primary CTA button (mock principle 06)
  verbLabel   String
  // Where the CTA points
  verbHref    String
  // Estimated $ impact — used for sort
  impactValue Decimal? @default(0)
  // Optional related entity IDs for joins later
  itemId      String?
  recipeId    String?
  // State
  status      String   @default("OPEN") // OPEN | APPLIED | SNOOZED | DISMISSED
  snoozeUntil DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status, severity])
  @@index([fingerprint])
}

// ── Temp charts ──────────────────────────────────────────────────────────
// Daily food-safety temperature logging. A TempUnit is a monitored piece of
// equipment (fridge/freezer/hot-hold) with a safe range; TempReadings are the
// timestamped temps logged against it. Out-of-range = temp below safeMin or
// above safeMax (either bound may be null for a one-sided limit).
enum TempUnitType {
  FRIDGE
  FREEZER
  HOT
}

model TempUnit {
  id              String         @id @default(cuid())
  name            String
  type            TempUnitType
  safeMin         Decimal? // °C, null = no lower bound
  safeMax         Decimal? // °C, null = no upper bound
  revenueCenterId String? // null = shared across all centers (mirrors Count)
  isActive        Boolean        @default(true) // soft-delete; readings stay in history
  sortOrder       Int            @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  readings        TempReading[]
  revenueCenter   RevenueCenter? @relation("TempUnitRC", fields: [revenueCenterId], references: [id], onDelete: SetNull)

  @@index([revenueCenterId, isActive])
}

model TempReading {
  id         String   @id @default(cuid())
  unitId     String
  logDate    String // 'YYYY-MM-DD' local day key
  time       String // 'HH:MM' local clock time of the reading
  temp       Decimal
  recordedBy String? // user name/email at log time
  createdAt  DateTime @default(now())
  unit       TempUnit @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@index([unitId, logDate])
}

// ── Toast POS integration (schema-only) ──────────────────────────────────────
// The Toast feature is PAUSED (REST API Canada-blocked; pivoted to SFTP nightly
// export — see feat/toast-integration). These models are kept here ONLY so the
// schema matches the live DB (the migrations were applied out-of-band). No app
// code on main references them. Full feature lives on feat/toast-integration.
model ToastConnection {
  id            String    @id @default("singleton")
  status        String    @default("disconnected") // 'disconnected' | 'ok' | 'error'
  lastSyncedAt  DateTime?
  lastError     String?
  lastSyncLogId String?
  updatedAt     DateTime  @updatedAt
}

model ToastItemMap {
  id            String   @id @default(cuid())
  toastItemGuid String   @unique
  toastName     String
  toastGroup    String?  // menu-group name from Menus API — drives food/non-food classification (classified on read)
  toastMenu     String?  // top-level menu name from Menus API — context for the mapping UI
  recipeId      String?
  lastSeenAt    DateTime @default(now())
  recipe        Recipe?  @relation("ToastItemRecipe", fields: [recipeId], references: [id], onDelete: SetNull)
}

// Maps Toast revenue-center GUIDs → app RevenueCenter. MANY-to-one: Fergie's has
// 3 Toast revenue centers feeding 2 app RCs (CAFE/CATERING), and the Config API
// that would name them is 403 — so GUIDs are discovered from order traffic and
// labelled by an admin. Supersedes the single `RevenueCenter.toastGuid` column.
model ToastRevenueCenterMap {
  id              String         @id @default(cuid())
  toastGuid       String         @unique
  revenueCenterId String?        // null until an admin labels it
  orderCountSeen  Int            @default(0) // last-known volume from discovery (display aid)
  lastSeenAt      DateTime       @default(now())
  locationId      String?
  location        Location?      @relation("ToastLocationMap", fields: [locationId], references: [id], onDelete: SetNull)
  revenueCenter   RevenueCenter? @relation("ToastRCMap", fields: [revenueCenterId], references: [id], onDelete: SetNull)
}

model ToastSyncLog {
  id               String   @id @default(cuid())
  windowStart      DateTime
  windowEnd        DateTime
  ordersPulled     Int      @default(0)
  lineItemsWritten Int      @default(0)
  unmatchedCount   Int      @default(0)
  status           String   @default("ok") // 'ok' | 'error'
  error            String?
  createdAt        DateTime @default(now())
}

model PrepTask {
  id                    String         @id @default(uuid())
  name                  String
  revenueCenterId       String
  linkedInventoryItemId String?
  sortOrder             Int            @default(0)
  isActive              Boolean        @default(true)
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  revenueCenter         RevenueCenter  @relation("PrepTaskRC", fields: [revenueCenterId], references: [id])
  linkedInventoryItem   InventoryItem? @relation("PrepTaskInventory", fields: [linkedInventoryItemId], references: [id])
  logs                  PrepTaskLog[]

  @@index([revenueCenterId])
}

model PrepTaskLog {
  id         String   @id @default(uuid())
  prepTaskId String
  logDate    DateTime
  createdAt  DateTime @default(now())
  prepTask   PrepTask @relation(fields: [prepTaskId], references: [id], onDelete: Cascade)

  @@unique([prepTaskId, logDate])
}

model EodCheckItem {
  id              String         @id @default(uuid())
  revenueCenterId String
  section         String
  title           String
  meta            String?
  sortOrder       Int            @default(0)
  isBlocker       Boolean        @default(false)
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  revenueCenter   RevenueCenter  @relation("EodCheckItemRC", fields: [revenueCenterId], references: [id])
  entries         EodCheckEntry[]

  @@index([revenueCenterId, isActive])
}

model EodClose {
  id              String          @id @default(uuid())
  revenueCenterId String
  businessDate    String          // 'YYYY-MM-DD' local day
  status          String          @default("DRAFT") // 'DRAFT' | 'CLOSED'
  handoverNote    String?
  labourCost      Decimal?
  grossSales      Decimal?
  compsVoids      Decimal?
  discounts       Decimal?
  signedOffBy     String?
  signedOffByName String?
  signedOffAt     DateTime?
  snapshot        Json?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  revenueCenter   RevenueCenter   @relation("EodCloseRC", fields: [revenueCenterId], references: [id])
  entries         EodCheckEntry[]

  @@unique([revenueCenterId, businessDate])
  @@index([revenueCenterId, status])
}

model EodCheckEntry {
  id            String       @id @default(uuid())
  closeId       String
  itemId        String
  done          Boolean      @default(false)
  updatedByName String?
  updatedAt     DateTime     @updatedAt
  close         EodClose     @relation(fields: [closeId], references: [id], onDelete: Cascade)
  item          EodCheckItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([closeId, itemId])
}
